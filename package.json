{
  "name": "onvio-helper",
  "version": "1.1.1",
  "description": "",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/dilelu94/onvio-helper.git"
  },
  "scripts": {
    "test": "vitest run --dir tests/unit",
    "dev": "vite",
    "start": "NODE_ENV=development electron .",
    "build:vite": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:vite && npm run build:electron",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.dilelu.onviohelper",
    "productName": "OnvioHelper",
    "publish": [
      {
        "provider": "github",
        "owner": "dilelu94",
        "repo": "onvio-helper"
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "scripts/**/*",
      "src/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5"
  }
}
